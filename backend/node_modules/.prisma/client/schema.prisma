generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

model User {
  id           String         @id @default(auto()) @map("_id") @db.ObjectId
  email        String         @unique
  userName     String?
  phone        String?
  fullName     String? 
  gender       String?
  birthday     String?
  avatar       String?
  age          Int?
  passwordHash String
  healthMetrics HealthMetric[]
  addresses    Address[]      
  createdAt    DateTime       @default(now())
}



model Food {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  title     String
  desc      String?
  kcal      Float
  category  String
  fullDesc  String?
  imageUrl  String?
  details   Json?
  createdAt DateTime @default(now()) 
}

model HealthMetric {
  id     String   @id @default(auto()) @map("_id") @db.ObjectId
  userId String   @db.ObjectId
  user   User     @relation(fields: [userId], references: [id])
  weight Float
  height Float?
  bmi    Float?
  date   DateTime @default(now())
}

model CalorieLog {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  userId    String?  @db.ObjectId
  foodName  String
  unit      String?
  qty       Int?
  calories  Float
  date      DateTime @default(now())
  createdAt DateTime @default(now())
}

model Address { 
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  userId    String   @db.ObjectId
  user      User     @relation(fields: [userId], references: [id])
  name      String
  phone     String
  fullAddress String
  isDefault Boolean  @default(false)
  createdAt DateTime @default(now())
}
